# Copy this file to `.env` for local development. Never commit a real `.env`.
#
# IMPORTANT: `drizzle.config.ts` uses `import "dotenv/config"`, which reads
# from `.env` (NOT `.env.local`). So `bun run db:push` and `bun run db:studio`
# will only see variables you put in `.env`. Next.js itself also loads
# `.env.local` at runtime — if you prefer that file, either duplicate
# `DATABASE_URL` into both or stick to `.env` for a single source of truth.
#
# OS-provided variables (`APPDATA` on Windows, `XDG_CONFIG_HOME` on Linux)
# are read by the collector but should never be set here.

# ============================================================
# apps/web — required
# ============================================================

# Postgres connection string. Read by Drizzle (server + drizzle-kit) and
# by `apps/web/lib/db/index.ts`.
DATABASE_URL=postgresql://user:pass@host:5432/pellametric

# Better-Auth server secret. 32 random bytes, hex-encoded.
#   openssl rand -hex 32
# The app refuses to start if this equals the build-time placeholder.
BETTER_AUTH_SECRET=

# Base URL Better-Auth uses when issuing callbacks (server-side).
BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth app credentials. Create the app at
#   https://github.com/settings/developers
# Homepage URL:     http://localhost:3000
# Callback URL:     http://localhost:3000/api/auth/callback/github
# Required scopes:  read:org, repo, read:user, user:email
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# 32-byte key (base64-encoded) used to encrypt stored prompts at rest.
# See `apps/web/lib/crypto/prompts.ts` — module throws if this is missing.
#   openssl rand -base64 32
PROMPT_MASTER_KEY=

# ============================================================
# apps/web — required (public, inlined into the client bundle at build)
# ============================================================

# Public site URL. Used for canonical links and OpenGraph metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public Better-Auth URL. Used by the browser auth client. Must resolve
# to the same origin as `BETTER_AUTH_URL` for local development.
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# ============================================================
# apps/web — optional
# ============================================================

# GitHub API token used for server-side repo/star/profile lookups.
# Optional in development (unauthenticated requests are rate-limited to
# 60/hour per IP); strongly recommended in production. A fine-grained PAT
# with `public_repo` read access is sufficient.
GITHUB_TOKEN=

# ============================================================
# apps/collector — runtime (normally written by `pella login`, not here)
# ============================================================

# Per-user ingest token (format: `pm_…`). Usually stored in
# ~/.pella/config.env by `pella login`; setting it here is only useful
# for one-shot `curl … | node - --token …` runs in dev.
PELLA_TOKEN=

# Override the collector's upload URL. Defaults to the build-time value
# baked by `PELLA_COLLECTOR_DEFAULT_URL` (see below), or
# `http://localhost:3000` during development.
PELLA_URL=

# Feature flag: set to `1` to skip Cursor session parsing.
PELLA_SKIP_CURSOR=0

# ============================================================
# apps/collector — build / dev-only
# ============================================================

# Default upload URL baked into `apps/web/public/collector.mjs` and the
# `pella` binary at build time. Only read by `apps/collector/build.ts`.
PELLA_COLLECTOR_DEFAULT_URL=https://pellametric.com

# Override for the `pella` binary path used by the daemon supervisor.
# Read by `apps/collector/src/daemon.ts`. Leave unset outside of local
# collector development.
PELLA_BIN=

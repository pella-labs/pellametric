# Bematist — environment variable example.
# Copy to .env and fill in real values. NEVER commit a .env with real secrets.

# ─── Server ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5433/bematist
CLICKHOUSE_URL=http://localhost:8123
REDIS_URL=redis://localhost:6379
INGEST_LISTEN_ADDR=:8000                  # custom JSON; OTLP HTTP on :4318
WEB_LISTEN_ADDR=:3000
BETTER_AUTH_SECRET=change-me-in-prod      # session signing
BETTER_AUTH_URL=http://localhost:3000     # base URL for Better Auth OAuth redirects (M4 PR 1)
GITHUB_CLIENT_ID=                         # GitHub OAuth app client id (for /auth/sign-in)
GITHUB_CLIENT_SECRET=                     # GitHub OAuth app client secret
BEMATIST_DEV_TENANT_ID=                   # pin the dashboard to a seeded org UUID (dev/perf only; unset in prod)
BEMATIST_DEV_ACTOR_ID=                    # optional — override the dev-mode user UUID
BEMATIST_DEV_ROLE=                        # optional — override the dev-mode role (admin | manager | engineer | auditor | viewer)
SLSA_PROVENANCE_KEY=                      # verifying installer signatures (Sprint 3)
ANTHROPIC_API_KEY=                        # BYO for Insight Engine; managed-cloud fallback in cloud only
OPENAI_API_KEY=                           # BYO for default embedding provider on self-host
EMBEDDING_PROVIDER=openai                 # openai (default) | voyage | ollama-nomic | xenova
EMBEDDING_DIM=512                         # 512 (Matryoshka for openai) | 768 nomic | 384 xenova
VOYAGE_API_KEY=                           # optional premium upgrade
SLACK_WEBHOOK_URL=                        # notifier
DISCORD_WEBHOOK_URL=                      # notifier
S3_ENDPOINT=                              # ClickHouse spillover destination
S3_ACCESS_KEY=
S3_SECRET=
TIER_C_MANAGED_CLOUD_OPTIN_ENFORCED=true  # default true on managed cloud
BEMATIST_COMPLIANCE_ENABLED=false         # gate /privacy (Bill of Rights) + future DPA/works-agreement/tier-picker/erasure UI; off for demo
SIGNED_CONFIG_PUBLIC_KEYS=                # comma-separated 32-byte hex Ed25519 public keys (D20 admin Tier-C flip)
SENTRY_DSN=                               # optional error reporting
LOG_LEVEL=info                            # pino level
NODE_OPTIONS=
BUN_RUNTIME_TRANSPILER=
RLIMIT_CORE=0                             # crash dumps disabled (security rule)

# ─── Collector (dev machine) ──────────────────────────────────────────────────
BEMATIST_ENDPOINT=http://localhost:8000   # sole switch between solo / self-host / hosted modes (D2)
BEMATIST_ORG=                             # injected by installer
BEMATIST_TOKEN=                           # bearer
BEMATIST_INGEST_HOST=https://ingest.example.com
BEMATIST_INGEST_ONLY_TO=                  # cert-pinned host (egress allowlist)
BEMATIST_DATA_DIR=~/.bematist
BEMATIST_POLICY_PATH=                     # override policy file lookup
BEMATIST_LOG_LEVEL=warn                   # quiet by default for dev UX
BEMATIST_DRY_RUN=0                        # 1 = log what would be sent, send nothing

# ─── GitHub App (bematist-github, from Workstream C) ──────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_CLIENT_ID=

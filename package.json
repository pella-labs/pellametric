{
  "name": "bematist",
  "version": "0.0.0",
  "private": true,
  "description": "Bematist — open-source AI-engineering analytics platform.",
  "license": "Apache-2.0",
  "packageManager": "bun@1.3.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --env-file=.env --filter='./apps/*' dev",
    "build": "bun --filter='./apps/*' --filter='./packages/*' build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "bun --filter='./apps/*' --filter='./packages/*' typecheck",
    "test": "bun --env-file=.env test",
    "test:e2e": "bun --env-file=.env --filter='./apps/web' test:e2e",
    "test:privacy": "echo 'test:privacy — not yet implemented; tracked in Workstream G (server + collector). Merge-blocker gate once available.' && exit 0",
    "test:scoring": "bun run packages/scoring/src/v1/eval/runner.ts",
    "test:perf": "bash tests/perf/run.sh",
    "fixtures:write": "bun run packages/scoring/src/v1/eval/write-fixtures.ts",
    "db:migrate:pg": "bun --env-file=.env --filter='@bematist/schema' migrate:pg",
    "db:migrate:ch": "bun --env-file=.env --filter='@bematist/schema' migrate:ch",
    "db:seed": "bun --env-file=.env --filter='@bematist/schema' seed",
    "generate:otel": "bun --filter='@bematist/otel' generate",
    "check:otel-generated": "bun --filter='@bematist/otel' check:generated"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/bun": "latest",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "engines": {
    "bun": ">=1.3.4"
  }
}

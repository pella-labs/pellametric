{
  "name": "pellametric",
  "private": true,
  "version": "0.0.1",
  "description": "Per-dev productivity metrics from Claude Code + Codex sessions, org-scoped via GitHub",
  "license": "MIT",
  "packageManager": "bun@1.3.9",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun --filter='./apps/web' run dev",
    "build": "bun --filter='./apps/collector' run build && bun --filter='./apps/web' run build",
    "start": "bun --filter='./apps/web' run start",
    "db:push": "bun --filter='./apps/web' run db:push",
    "db:studio": "bun --filter='./apps/web' run db:studio",
    "collector": "bun --filter='./apps/collector' run start",
    "test": "bun --filter='./apps/*' --filter='./packages/*' run test",
    "typecheck": "bun --filter='./apps/*' --filter='./packages/*' run typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.3.4"
  }
}

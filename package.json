{
  "name": "bematist",
  "version": "0.0.0",
  "private": true,
  "description": "DevMetrics — open-source AI-engineering analytics platform (repo slug: bematist)",
  "license": "Apache-2.0",
  "packageManager": "bun@1.2.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter='./apps/*' dev",
    "build": "bun --filter='./apps/*' --filter='./packages/*' build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "bun --filter='./apps/*' --filter='./packages/*' typecheck",
    "test": "bun test",
    "test:e2e": "bun --filter='./apps/web' test:e2e",
    "db:migrate:pg": "bun --filter='@bematist/schema' migrate:pg",
    "db:migrate:ch": "bun --filter='@bematist/schema' migrate:ch",
    "db:seed": "bun --filter='@bematist/schema' seed"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/bun": "latest",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "drizzle-orm": "0.36.4",
    "zod": "^3.23.8"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}

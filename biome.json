{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/build",
      "!**/.next",
      "!**/out",
      "!**/coverage",
      "!.claude/worktrees",
      "!.worktrees",
      "!**/*.sqlite",
      "!**/*.db",
      "!bun.lock",
      "!**/next-env.d.ts",
      "!packages/ui/src/styles/theme.css",
      "!**/*.md",
      "!packages/otel/src/gen",
      "!packages/otel/vendor",
      "!packages/fixtures/github/**/*.json",
      "!packages/fixtures/github/.webhook-secret"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always"
    }
  },
  "json": {
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "warn",
        "useImportType": "error",
        "noDescendingSpecificity": "off"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noConsole": {
          "level": "warn",
          "options": { "allow": ["warn", "error", "info"] }
        },
        "noArrayIndexKey": "warn",
        "noEmptyBlock": "off"
      },
      "correctness": {
        "noUnusedVariables": "warn",
        "noUnusedImports": "warn"
      },
      "complexity": {
        "noUselessSwitchCase": "warn",
        "noImportantStyles": "off"
      },
      "performance": {
        "noImgElement": "off"
      },
      "a11y": {
        "useAriaPropsSupportedByRole": "warn",
        "noLabelWithoutControl": "warn"
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "apps/collector/scripts/**",
        "apps/collector/src/cli.ts",
        "apps/collector/src/commands/**",
        "apps/ingest/src/smoke.ts",
        "apps/worker/src/index.ts",
        "apps/web/integration-tests/**",
        "packages/scoring/src/v1/eval/**",
        "packages/schema/scripts/**"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    }
  ]
}

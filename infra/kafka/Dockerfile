# Bematist — Kafka broker (Apache) in KRaft mode for Railway dev.
# Named "redpanda" for historical reasons (the private domain is locked).
# Configured entirely via KAFKA_* env vars on the service.
#
# apache/kafka is the official Apache image. Bitnami's public tags were
# deprecated in Aug 2025; using apache/kafka avoids the licensing tier.
FROM apache/kafka:3.9.1

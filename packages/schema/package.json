{
  "name": "@bematist/schema",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./postgres": "./postgres/schema.ts",
    "./postgres/migrations/*": "./postgres/migrations/*"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "migrate:pg": "bun postgres/migrate.ts",
    "migrate:ch": "bun clickhouse/migrate.ts",
    "seed": "bun scripts/seed.ts",
    "drizzle:generate": "drizzle-kit generate --config=postgres/drizzle.config.ts"
  },
  "dependencies": {
    "@clickhouse/client": "^1.7.0",
    "drizzle-orm": "0.36.4",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.28.1",
    "typescript": "^5.6.3"
  }
}

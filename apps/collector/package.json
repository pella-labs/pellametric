{
  "name": "@pella/collector",
  "version": "0.0.1",
  "private": true,
  "bin": {
    "pella-collect": "./dist/index.js"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --define:__DEFAULT_URL__='\"https://pella-web-production.up.railway.app\"' --outfile=../web/public/collector.mjs",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@pella/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}

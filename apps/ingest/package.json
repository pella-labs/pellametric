{
  "name": "@bematist/ingest",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "dev:live": "REDIS_URL=redis://localhost:6379 CLICKHOUSE_URL=http://localhost:8123 bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "smoke": "bun run src/smoke.ts"
  },
  "dependencies": {
    "@bematist/config": "workspace:*",
    "@bematist/otel": "workspace:*",
    "@bematist/redact": "workspace:*",
    "@bematist/schema": "workspace:*",
    "@clickhouse/client": "^1.18.2",
    "drizzle-orm": "0.36.4",
    "kafkajs": "^2",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "redis": "^4.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.3"
  }
}
